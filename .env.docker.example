# Root .env for docker compose — infrequent changes recommended
# Copy to .env and adjust as needed

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BASE_DOMAIN=localhost
# Telemetry / LLM (optional)
LLM_API_KEY=
LLM_API_BASE_URL=http://host.docker.internal:42005/v1
LLM_API_MODEL=qwen-coder
# Backend CORS (comma-separated)
CORS_ORIGINS=http://127.0.0.1:8000,http://127.0.0.1:8080
