# .env.bot.example — Restaurant Allergen Bot configuration

# Required
BOT_TOKEN=123456:your-telegram-bot-token

# Backend API
BACKEND_API_URL=http://backend:8000
BACKEND_API_KEY=supersecret

# Optional LLM for natural language understanding
LLM_API_KEY=your-llm-api-key
LLM_API_BASE_URL=http://host.docker.internal:42005/v1
LLM_API_MODEL=qwen-coder
